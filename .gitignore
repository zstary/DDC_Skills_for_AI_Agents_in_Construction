node_modules/
*.tsbuildinfo
.npm
.eslintcache
.node_repl_history
*.tgz
.yarn-integrity
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*
*.js.map
*.d.ts.map

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
*.sublime-project

# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
.directory
.Apple*
.LSOverride

# Environment
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Testing
htmlcov/
.nyc_output
coverage/

# Temporary files
*.tmp
*.temp
*.bak
.cache/
tmp/
temp/

# Database files
*.db
*.sqlite

# Build outputs
output
outputs/
extras/
