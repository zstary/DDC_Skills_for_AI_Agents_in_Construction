# >>> claude-plugin:general:gitignore:start <<<
# Managed by claude-plugin 'general' — do not edit manually

# Everything under .claude/ is runtime/machine-specific — ignore the whole directory,
# except settings.json which captures project-level plugin configuration (enabledPlugins).
.claude/*
!.claude/settings.json

# Project-level MCP override (machine-specific; not part of plugin distribution)
.mcp.json

# AGENTS.md is regenerated each session from plugin templates
AGENTS.md

# CLAUDE.md is a symlink → AGENTS.md; recreated by plugin on each install
CLAUDE.md

# .clinerules/00-shared.md is a symlink → ../AGENTS.md; recreated by plugin
.clinerules/00-shared.md

# Runtime session logs (written by hooks, machine-specific)
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Ruff validator log (written next to the validator script at runtime)
plugins/general/hooks/validators/ruff_validator.log

# Python
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
env.bak/
venv.bak/
.venv
pip-log.txt
pip-delete-this-directory.txt
.tox/
.coverage
.coverage.*
.pytest_cache/
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytype/
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
*.egg-info/
dist/
build/
*.egg

