      "Bash(aws * register-*)",
      "Bash(aws * restore-*)",
      "Bash(aws * copy-*)",
      "Bash(aws * replicate-*)",
      "Bash(aws * modify-*)",
      "Bash(aws * update-*)",
      "Bash(aws * put-*)",
      "Bash(aws * set-*)",
      "Bash(aws * replace-*)",
      "Bash(aws * reset-*)",
      "Bash(aws * change-*)",
      "Bash(aws * apply-*)",
      "Bash(aws * upload-*)",
      "Bash(aws * tag-*)",
      "Bash(aws * untag-*)",
      "Bash(aws * attach-*)",
      "Bash(aws * detach-*)",
      "Bash(aws * associate-*)",
      "Bash(aws * disassociate-*)",
      "Bash(aws * add-*)",
      "Bash(aws * authorize-*)",
      "Bash(aws * revoke-*)",
      "Bash(aws * enable-*)",
      "Bash(aws * disable-*)",
      "Bash(aws * rotate-*)",
      "Bash(aws * schedule-*)",
      "Bash(aws * stop-*)",
      "Bash(aws * start-*)",
      "Bash(aws * reboot-*)",
      "Bash(aws * release-*)",
      "Bash(aws * failover-*)",
      "Bash(aws * promote-*)",
      "Bash(aws s3 rm *)",
      "Bash(aws s3 rb *)",
      "Bash(aws s3 mv *)"
    ],
    "ask": [
      "Bash(rm *)",
      "Bash(rmdir *)",
      "Bash(rm **/.github/**)",
      "Bash(rmdir **/.github/**)",
      "Bash(git rm **/.github/**)",
      "Write(**/.github/**)",
      "Edit(**/.github/**)",
      "Write(.env)",
      "Write(.env.*)",
      "Write(**/.env)",
      "Write(**/.env.*)",
      "Write(**/credentials/**)",
      "Write(**/secrets/**)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Edit(**/credentials/**)",
      "Edit(**/secrets/**)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/credentials/**)",
      "Read(**/secrets/**)",
      "Bash(git push *)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "model": "claude-sonnet-latest[1m]",
  "statusLine": {
    "type": "command",
    "command": "/bin/sh -c 'npx -y ccstatusline@latest'",
    "padding": 0
  },
  "enabledPlugins": {
    "code-simplifier@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "general@impact-claude-market": true,
    "claude-code-setup@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "my-office@impact-claude-market": true,
    "impact-concur@impact-claude-market": true,
    "impact-python@impact-claude-market": true,
    "impact-powershell@impact-claude-market": true
  },
  "extraKnownMarketplaces": {
    "impact-claude-market": {
      "source": {
        "source": "git",
        "url": "https://github.concur.com/impact/impact-claude-market.git"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "tui": "fullscreen",
  "autoDreamEnabled": true,
  "autoCompactEnabled": true,
  "gitAttribution": false
}
