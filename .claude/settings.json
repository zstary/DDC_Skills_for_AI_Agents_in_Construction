{
  "cleanupPeriodDays": 7,
  "env": {
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "claude-haiku-latest[1m]",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "claude-opus-latest[1m]",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "claude-sonnet-latest[1m]",
    "ANTHROPIC_MODEL": "claude-sonnet-latest[1m]",
    "CLAUDE_CODE_SUBAGENT_MODEL": "claude-sonnet-latest[1m]",
    "DISABLE_BUG_COMMAND": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_TELEMETRY": "1",
    "ENABLE_TOOL_SEARCH": "true",
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "true",
    "CLAUDE_CODE_NEW_INIT": "1",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "80",
    "CLAUDE_CODE_MAX_TOOL_USE_CONCURRENCY": "15",
    "CLAUDE_CODE_ENABLE_BACKGROUND_PLUGIN_REFRESH": "1",
    "CLAUDE_CODE_SYNC_PLUGIN_INSTALL": "1",
    "CLAUDE_CODE_RESUME_INTERRUPTED_TURN": "1",
    "CLAUDE_AUTO_BACKGROUND_TASKS": "1",
    "CLAUDE_CODE_FORK_SUBAGENT": "1",
    "CLAUDE_CODE_DISABLE_AUTO_MEMORY": "0",
    "TRACE_TO_LANGFUSE": "false",
    "LANGFUSE_BASE_URL": "http://localhost:3333"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "Agent",
      "Search",
      "Edit",
      "Write",
      "mcp__*",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(echo *)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Bash(wc *)",
      "Bash(pwd *)",
      "Bash(cd *)",
