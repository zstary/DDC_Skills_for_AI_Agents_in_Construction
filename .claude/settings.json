    "deny": [
      "Bash(shred *)",
      "Bash(git push *force*)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -f *)",
      "Bash(git clean -fd *)",
      "Bash(git rebase *)",
      "Bash(gh repo delete *)",
      "Bash(gh issue delete *)",
      "Bash(gh release delete *)",
      "Bash(gh pr close *--delete-branch*)",
      "Bash(gh pr close *-d*)",
      "Bash(gitcli undo *)",
      "Bash(git push *origin production*)",
      "Bash(sudo *)",
      "Bash(su *)",
      "Bash(reboot *)",
      "Bash(shutdown *)",
      "Bash(git push *origin main*)",
      "Bash(git push *origin master*)",
      "Bash(aws * delete-*)",
      "Bash(aws * terminate-*)",
      "Bash(aws * remove-*)",
      "Bash(aws * deregister-*)",
      "Bash(aws * deactivate-*)",
      "Bash(aws * create-*)",
      "Bash(aws * run-*)",
      "Bash(aws * allocate-*)",
